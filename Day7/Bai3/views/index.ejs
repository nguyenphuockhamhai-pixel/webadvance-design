<!DOCTYPE html>
<html>
<head>
    <title>Calculate Square</title>
</head>
<body>

<h1>Calculate Square Perimeter and Area</h1>

<form action="/calculate" method="POST">

<label>Side Length:</label>
<input type="number" name="sideLength" required>

<br><br>

<button type="submit">Calculate</button>

</form>

<% if (perimeter !== null && area !== null) { %>

<h2>Perimeter: <%= perimeter %></h2>
<h2>Area: <%= area %></h2>

<% } %>

</body>
</html>